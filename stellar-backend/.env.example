# ─── Environment ───────────────────────────────────────
NODE_ENV=development
PORT=9200
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://stellar_user:password@127.0.0.1:5433/stellar_db
DB_PASSWORD=your_secure_password

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://:password@127.0.0.1:6380
REDIS_PASSWORD=your_redis_password

# ─── JWT Authentication ────────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_chars_required_for_security
JWT_EXPIRATION=7d

# ─── Blockchain (Sepolia) ──────────────────────────────
BLOCKCHAIN_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SGL_TOKEN_ADDRESS=0xF281a68ae5Baf227bADC1245AC5F9B2F53b7EDe1
AVATAR_BASE_ADDRESS=0x95F531cafca627A447C0F1119B8b6aCC730163E5
TIME_CAPSULE_ADDRESS=0x6A58aD664071d450cF7e794Dac5A13e3a1DeD172
CONSENT_REGISTRY_ADDRESS=0x0Ee8f5dC7E9BC9AF344eB987B8363b33E737b757
DIGITAL_LEGACY_ADDRESS=0x0Ee8f5dC7E9BC9AF344eB987B8363b33E737b757
AVATAR_WALLET_LINK_ADDRESS=0x9F475e5D174577f2FB17a9D94a8093e2D8c9ED41

# ─── Payment / SGL ─────────────────────────────────────
SGL_DISTRIBUTOR_PRIVATE_KEY=your_private_key_here_do_not_share
TREASURY_ADDRESS=0xtreasury_address_here

# ─── Solana Devnet Real Layer ───────────────────────────
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SGL_NETWORK=solana-devnet
SGL_MINT_ADDRESS=
SGL_AUTHORITY_WALLET=
SGL_TREASURY_WALLET=
SGL_DEPLOYER_KEYPAIR_PATH=/root/.config/solana/singulai/singulai-devnet-deployer.json
SGL_INITIAL_CREDIT=10000
SGL_DECIMALS=9
PUBLIC_APP_URL=https://singulai.live

# ─── GDPR / Compliance ─────────────────────────────────
DATA_RETENTION_DAYS=180
CONSENT_VERIFICATION_ENABLED=true

# ─── Email / Notifications ────────────────────────────
SMTP_HOST=smtp.email.com
SMTP_PORT=587
SMTP_USER=noreply@rodrigo.run
SMTP_PASSWORD=email_password

# ─── API Configuration ────────────────────────────────
CORS_ORIGIN=http://localhost:5173,https://stellar-canvas.rodrigo.run
API_VERSION=v1
API_PREFIX=/api/v1

# ─── Monitoring ────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here
ENABLE_MONITORING=false

# ─── Frontend Integration ──────────────────────────────
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://stellar-canvas.rodrigo.run

# ─── Avatar Interaction Expansion (pending rollout) ────
# Feature flags
AVATAR_INTERACTION_EXPANSION_ENABLED=false
AVATAR_VOICE_SYNTHESIS_ENABLED=false

# ElevenLabs (voice)
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1
ELEVENLABS_DEFAULT_VOICE_ID=

# Custom providers (tenant/user-owned API)
CUSTOM_LLM_ENDPOINT=
CUSTOM_LLM_API_KEY=
CUSTOM_TTS_ENDPOINT=
CUSTOM_TTS_API_KEY=

# Provider Plans and User Model Selection (pending rollout)
AI_PROVIDER_PLANS_ENABLED=false
AI_PROVIDER_SELECTION_MODE=tenant-controlled
AI_PROVIDER_DEFAULT_MODEL_ID=
AI_PROVIDER_ALLOW_USER_MODEL_CHOICE=false

# Native low-cost model strategy (Ollama on VPS)
AI_NATIVE_MODEL_ENABLED=true
AI_NATIVE_MODEL_PROVIDER=ollama
AI_NATIVE_MODEL_ID=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Fine-tuning backlog
AI_PREMIUM_MODEL_PENDING_TUNING=true
