{
  "name": "stellar-backend",
  "version": "1.0.0",
  "description": "Stellar Canvas Dynamics Backend - Enterprise-grade microservices for Web3 avatar platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "stop": "pkill -f 'node.*server.js'",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --runInBand",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage",
    "lint": "eslint -c eslint.config.js src",
    "lint:fix": "eslint -c eslint.config.js src --fix",
    "typecheck": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "stellar",
    "web3",
    "avatar",
    "blockchain",
    "gdpr",
    "nodejs",
    "express",
    "typescript"
  ],
  "author": "Run (Chefe Desenvolvimento)",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bs58": "^6.0.0",
    "bull": "^4.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.0.0",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^5.0.0",
    "redis": "^4.6.0",
    "winston": "^3.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.43.0",
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
  }
}
