# Variaveis de ambiente para deploy Sepolia - Modulo 2 Avatares Evolutivos
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA versione o arquivo .env

SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID
DEPLOYER_PRIVATE_KEY=0xSUA_CHAVE_PRIVADA

# Enderecos de deploy
ADMIN_ADDRESS=0xSEU_ENDERECO_ADMIN
TREASURY_ADDRESS=0xSEU_ENDERECO_TREASURY

# Integracao com Modulo 3 (SGL Token ja deployado)
SGL_TOKEN_ADDRESS=0xENDERECO_DO_SGLTOKEN_SEPOLIA